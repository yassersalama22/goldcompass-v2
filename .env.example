# Public base URL of the site (used for metadata, canonical URLs, sitemap, robots).
# No trailing slash. Example for local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://goldcompass.app

# --- Recommendation pipeline (Phase 3.5 / Aureus v2) ---
# Anthropic API key for the outlook generator. If unset, the pipeline uses the
# deterministic mock generator (so it runs offline / in CI without a key).
# Set in .env.local locally, and as a GitHub Actions secret for the daily job.
ANTHROPIC_API_KEY=

# Optional: tune cost/quality of the outlook generator.
# OUTLOOK_MODEL=claude-opus-4-8        # e.g. claude-sonnet-4-6 is ~2x cheaper
# OUTLOOK_EFFORT=medium                # low | medium | high | xhigh | max
# OUTLOOK_WEB_SEARCH_MAX_USES=4        # fewer searches = lower cost
# OUTLOOK_GENERATOR=mock               # force the offline mock generator

# Optional: tune cost/quality of the article generator (same ANTHROPIC_API_KEY).
# ARTICLE_MODEL=claude-opus-4-8
# ARTICLE_EFFORT=medium
# ARTICLE_WEB_SEARCH_MAX_USES=5
# ARTICLE_GENERATOR=mock
# ARTICLE_TOPIC=...                    # steer a specific article topic

# Secret for the on-demand revalidation endpoint (POST /api/revalidate?secret=...).
REVALIDATE_SECRET=

# --- Newsletter / Subscribe (Phase 6) ---
# Buttondown API key for email capture. If unset, the subscribe form uses the
# inert provider (logs the email, stores nothing) so dev/CI builds work offline.
# Get a key at https://buttondown.email (Settings → API).
BUTTONDOWN_API_KEY=
# Optional: force the inert provider even when a key is set.
# NEWSLETTER_PROVIDER=inert

# Cloudflare Turnstile (bot protection on the subscribe form). Both keys come
# from the Turnstile dashboard (https://dash.cloudflare.com → Turnstile). If
# unset, the check is inert (form works, no verification) so dev/CI run offline.
# The site key is public (sent to the browser); the secret key must stay private.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analytics & search (growth) ---
# Cloudflare Web Analytics beacon token (dash.cloudflare.com → Analytics → Web
# Analytics → add site, "manual" install). Public; inlined at BUILD time (set as
# a GitHub Actions repo variable so deploy.yml can pass it as a build-arg).
# Unset = no analytics script is loaded.
NEXT_PUBLIC_CF_BEACON_TOKEN=
# Google Search Console meta-tag verification token (content value of the
# <meta name="google-site-verification"> tag). Only needed if NOT verifying via
# DNS TXT record (DNS verification is preferred — no rebuild required).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
